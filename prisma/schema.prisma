generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id
  email               String    @unique
  name                String
  phone               String?
  passwordHash        String
  clientCode          String?   @unique
  avatar              String?
  birthday            String?
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  verifiedBy          String?
  totalOrders         Int       @default(0)
  totalSpent          Float     @default(0)
  lastActivityAt      DateTime?
  lastLoginAt         DateTime?
  lastOrderAt         DateTime?
  adminNote                String?
  retentionNotifiedAt      DateTime?
  role                     String    @default("client")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  passwordResetToken       String?   @unique
  passwordResetExpiresAt   DateTime?

  referredByCode     String?
  birthDate          DateTime?
  lastBirthdayReward DateTime?

  googleId     String? @unique
  facebookId   String? @unique
  avatarUrl    String?
  authProvider String?

  orders               Order[]
  reservations         Reservation[]
  loyaltyProfile       LoyaltyProfile?
  rewardLedger         RewardLedger[]
  walletTransactions   WalletTransaction[]
  referralsMade        Referral[]          @relation("ReferralsMade")
  referredBy           Referral?           @relation("ReferredBy")
  orderReviews         OrderReview[]
}

model Order {
  id              String   @id
  userId          String?
  userEmail       String?
  name            String   @default("")
  phone           String   @default("")
  orderType       String
  status          String   @default("noua")
  paymentMethod   String
  paymentStatus   String   @default("pending")
  items           Json
  subtotal        Float
  deliveryFee     Float    @default(0)
  discountAmount  Float    @default(0)
  discountCode    String?
  total           Float
  address         String?
  addressDetails  String?
  city            String?
  notes           String?
  observation     String?
  userLat         Float?
  userLng         Float?
  freeCode        String?
  discountApplied String?
  processedBy     Json?
  isPriority        Boolean  @default(false)
  priorityLevel     Int?
  reviewEmailSent   Boolean  @default(false)
  reviewEmailSentAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  review OrderReview?
}

model Reservation {
  id            String   @id
  userId        String?
  name          String   @default("")
  email         String   @default("")
  phone         String   @default("")
  location      String
  date          String
  time          String
  guests        Int
  eventType     String?
  notes         String?
  status        String   @default("noua")
  observation   String?
  adminNote     String?
  notifications Json     @default("[]")
  processedBy   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  text      String
  date      String?
  source    String   @default("manual")
  approved  Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSettings {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model GdprRequest {
  id              String    @id
  receivedAt      DateTime
  deadline        DateTime?
  requesterEmail  String
  requesterName   String
  type            String
  status          String    @default("pending")
  notes           String?
  processedAt     DateTime?
  relatedUserId   String?
  createdAt       DateTime  @default(now())
}

enum WalletTransactionType {
  CASHBACK_EARNED
  CASHBACK_EXPIRED
  CREDIT_USED
  CREDIT_EXPIRED
  MANUAL_CREDIT
  MANUAL_DEBIT
  LEVEL_BONUS
  REFERRAL_CASHBACK
  REFERRAL_WELCOME
  BIRTHDAY_CREDIT
}

enum ReferralStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum RewardStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

model LoyaltyProfile {
  id                          String    @id @default(cuid())
  userId                      String    @unique
  user                        User      @relation(fields: [userId], references: [id])
  totalCompletedOrders        Int       @default(0)
  completedOrdersCurrentMonth Int       @default(0)
  currentTier                 String?
  currentLevel                Int       @default(1)
  walletBalance               Float     @default(0)
  totalSpentEligible          Float     @default(0)
  firstCompletedOrderAt       DateTime?
  lastCompletedOrderAt        DateTime?
  referralCode                String?   @unique
  processedOrderIds           String[]  @default([])
  walletExpiresAt             DateTime?
  totalCashbackEarned         Float     @default(0)
  level3BonusChoice           String?
  level3BonusChosenAt         DateTime?
  level3BonusExpiresAt        DateTime?
  level3CashbackBoostLeft     Int       @default(0)
  priorityDelivery            Boolean   @default(false)
  totalReferrals              Int       @default(0)
  referralCashbackEarned      Float     @default(0)
  welcomeBonusActive          Boolean   @default(false)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  rewardGrants       RewardGrant[]
  walletTransactions WalletTransaction[]
  rewards            RewardLedger[]
}

model Referral {
  id                  String        @id @default(cuid())
  referrerId          String
  referrer            User          @relation("ReferralsMade", fields: [referrerId], references: [id])
  referredUserId      String        @unique
  referredUser        User          @relation("ReferredBy", fields: [referredUserId], references: [id])
  status              ReferralStatus @default(PENDING)
  referredOrdersCount Int           @default(0)
  totalCashbackEarned Float         @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model RewardLedger {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  loyaltyProfileId String
  loyaltyProfile   LoyaltyProfile @relation(fields: [loyaltyProfileId], references: [id])
  campaignId       String?
  levelId          Int?
  rewardType       String
  rewardValue      Float
  rewardMetadata   Json?
  status           RewardStatus @default(ACTIVE)
  triggerOrderId   String?
  uniqueRewardKey  String       @unique
  issuedAt         DateTime     @default(now())
  expiresAt        DateTime?
  usedAt           DateTime?
  usedOnOrderId    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model RewardGrant {
  id               String    @id @default(cuid())
  loyaltyProfileId String
  campaignId       String
  rewardType       String
  code             String?   @unique
  discountPercent  Float?
  maxOrderValue    Float?
  maxDiscount      Float?
  freeProductId    String?
  walletCredit     Float?
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime?
  usedAt           DateTime?
  usedOnOrderId    String?
  status           String    @default("active")
  triggerOrderId   String?
  uniqueRewardKey  String    @unique
  createdAt        DateTime  @default(now())

  loyaltyProfile LoyaltyProfile @relation(fields: [loyaltyProfileId], references: [id])
}

model WalletTransaction {
  id               String                @id @default(cuid())
  loyaltyProfileId String
  userId           String
  type             WalletTransactionType
  amount           Float
  balanceBefore    Float                 @default(0)
  balanceAfter     Float                 @default(0)
  orderId          String?
  sourceOrderId    String?
  usedOnOrderId    String?
  description      String?
  expiresAt        DateTime?
  createdAt        DateTime              @default(now())

  loyaltyProfile LoyaltyProfile @relation(fields: [loyaltyProfileId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
}

model CampaignSettings {
  id        String   @id @default(cuid())
  name      String
  type      String
  isActive  Boolean  @default(true)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuCategory {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String
  subcategory String?
  name        String
  description String?
  price       Float
  unit        String?
  image       String?
  status      String   @default("disponibil")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  date        String?
  excerpt     String?
  content     String
  image       String?
  category    String    @default("events")
  status      String    @default("draft")
  publishAt   String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SpecialEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String?
  time        String?
  location    String?
  image       String?
  ctaLabel    String?
  ctaUrl      String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Operator {
  id                         String    @id @default(cuid())
  name                       String
  username                   String    @unique
  role                       String    @default("operator")
  passwordHash               String
  pin                        String?
  isActive                   Boolean   @default(true)
  totalOrdersProcessed       Int       @default(0)
  totalReservationsProcessed Int       @default(0)
  loginHistory               Json      @default("[]")
  activityLog                Json      @default("[]")
  createdAt                  DateTime  @default(now())
  lastLoginAt                DateTime?
  lastActivityAt             DateTime?
}

model SupportRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderReview {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  rating       Int
  comment      String?
  isLowRating  Boolean  @default(false)
  adminAlerted Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model WeeklyReport {
  id              String   @id @default(cuid())
  weekStart       DateTime
  weekEnd         DateTime
  totalRevenue    Float
  totalOrders     Int
  completedOrders Int
  cancelledOrders Int
  newCustomers    Int
  avgOrderValue   Float
  topProducts     Json
  peakDay         String
  peakHour        Int
  revenueByDay    Json
  pdfUrl          String?
  emailSentAt     DateTime?
  createdAt       DateTime @default(now())
}
